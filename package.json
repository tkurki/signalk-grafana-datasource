    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin-ts": "^4.4.1",
    "@swc/core": "^1.15.43",
    "@swc/helpers": "^0.5.23",
    "@swc/jest": "^0.2.39",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/jest": "^30.0.0",
    "@types/js-quantities": "^1.6.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^26.1.0",
